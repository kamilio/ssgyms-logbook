{
  "name": "@kamilio/ssgyms-logbook",
  "version": "0.1.0",
  "description": "Toolcraft CLI and MCP server for the Starting Strength Gyms logbook",
  "homepage": "https://github.com/kamilio/ssgyms-logbook#readme",
  "bugs": {
    "url": "https://github.com/kamilio/ssgyms-logbook/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamilio/ssgyms-logbook.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "ssgyms-logbook": "dist/cli.js",
    "ssgyms-logbook-mcp": "dist/mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/cli.js dist/mcp.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "toolcraft": "^0.0.131",
    "toolcraft-schema": "^0.0.131"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
